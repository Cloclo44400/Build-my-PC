rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /configs/{configId} {

      // Tout le monde peut lire les configs publiées (communauté publique)
      allow read: if true;

      // Créer une config : il faut être connecté, et être déclaré comme auteur
      allow create: if request.auth != null
                    && request.resource.data.authorId == request.auth.uid
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() < 200
                    && request.resource.data.components is list;

      // Modifier une config :
      // - l'auteur peut tout modifier (édition de sa propre config)
      // - un autre utilisateur connecté peut UNIQUEMENT modifier likes / ratings / viewedBy / views
      //   (empêche de trafiquer le nom, le prix, les composants d'une config qui n'est pas la sienne)
      allow update: if request.auth != null && (
        resource.data.authorId == request.auth.uid
        ||
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['likes', 'ratings', 'viewedBy', 'views'])
      );

      // Supprimer : seul l'auteur peut supprimer sa config
      allow delete: if request.auth != null && resource.data.authorId == request.auth.uid;
    }
  }
}
